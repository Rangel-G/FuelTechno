# Template de Configurações - Copie este arquivo como '.env' e ajuste os valores

# Configurações da Fita LED BLE
LED_DEVICE_NAME=LEDDMX-000101
LED_CHAR_UUID=0000ffe1-0000-1000-8000-00805f9b34fb

# Configurações de Conexão Serial (ELM327 OBD2)
# Deixe em branco para usar detecção automática baseada no OS (COM4 no Windows / /dev/rfcomm0 no Linux)
SERIAL_PORT=COM4
BAUD_RATE=38400

# Configurações do Servidor WebSocket
WS_HOST=127.0.0.1
WS_PORT=8765

# Limite de RPM do Shift Light (Acionamento dos LEDs)
LED_REDLINE_RPM=3000

# Cores do Shift Light (Formato RGB: R,G,B)
LED_COLOR_NORMAL=0,0,255
LED_COLOR_REDLINE=255,0,0

# Nível de Logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
